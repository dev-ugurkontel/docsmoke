{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dev-ugurkontel.github.io/docsmoke/schemas/report.schema.json",
  "title": "docsmoke JSON report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "started_at",
    "finished_at",
    "duration_seconds",
    "summary",
    "results"
  ],
  "properties": {
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "skipped",
        "errors"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snippet",
        "status",
        "duration_seconds",
        "exit_code",
        "stdout",
        "stderr",
        "message"
      ],
      "properties": {
        "snippet": {
          "$ref": "#/$defs/snippet"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "error"
          ]
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "snippet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "path",
        "language",
        "executor",
        "start_line",
        "end_line"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "executor": {
          "type": "string",
          "minLength": 1
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
